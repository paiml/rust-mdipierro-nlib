 pub fn simpson(f: impl Fn(f64) -> f64, a: f64, b: f64, n: usize) -> f64 {
     assert!(a < b, "simpson: a must be less than b");
     assert!(n > 0, "simpson: n must be positive");
     assert!(n % 2 == 0, "simpson: n must be even");
