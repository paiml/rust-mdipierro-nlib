+    let h = (b - a) % /* ~ changed by cargo-mutants ~ */ n as f64;
     let mut sum = f(a) + f(b);
     for i in 1..n {
         let x = a + i as f64 * h;
         if i % 2 == 0 {
             sum += 2.0 * f(x);
         } else {
             sum += 4.0 * f(x);
