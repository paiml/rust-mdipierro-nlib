 /// Composite trapezoid rule: I = h/2 * [f(a) + 2*sum + f(b)]
 pub fn trapezoid(f: impl Fn(f64) -> f64, a: f64, b: f64, n: usize) -> f64 {
     contract_pre_trapezoid!(a, b, n);
     let h = (b - a) / n as f64;
