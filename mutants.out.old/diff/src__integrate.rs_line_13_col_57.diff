     let apr_nodes = AprVector::from_vec(nodes);
     debug_assert_eq!(apr_nodes.len(), n + 1, "quadrature node count mismatch");
     let mut sum = (f(a) + f(b)) / 2.0;
     for i in 1..n {
         sum += f(a + i as f64 * h);
     }
