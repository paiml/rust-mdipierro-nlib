 /// Raw Simpson on 2 panels (3 points).
 fn simpson_raw(f: &impl Fn(f64) -> f64, a: f64, b: f64) -> f64 {
     let mid = (a + b) / 2.0;
     let h = (b - a) / 6.0;
     h * (f(a) + 4.0 * f(mid) + f(b))
 }
