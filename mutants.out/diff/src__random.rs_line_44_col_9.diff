 /// Returns (value, next_state) for a single LCG step.
 pub fn lcg_next(state: u64, a: u64, c: u64, m: u64) -> (u64, u64) {
     assert!(m > 0, "lcg_next: modulus m must be > 0");
     let next = ((a as u128 * state as u128 + c as u128) % m as u128) as u64;
     (next, next)
